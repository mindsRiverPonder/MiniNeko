<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="0dp">

        <TextView
            android:id="@+id/tv_temperature_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Temperature 0.70" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_temperature"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="1.5"
            android:stepSize="0.05"
            app:tickVisible="false" />

        <TextView
            android:id="@+id/tv_top_p_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Top-P 1.00" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_top_p"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0.1"
            android:valueTo="1.0"
            android:stepSize="0.05"
            app:tickVisible="false" />

        <TextView
            android:id="@+id/tv_top_k_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Top-K off" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_top_k"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            app:tickVisible="false" />

        <TextView
            android:id="@+id/tv_predict_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Max reply 100" />

        <com.google.android.material.slider.Slider
            android:id="@+id/slider_predict_length"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="32"
            android:valueTo="4090"
            android:stepSize="1"
            app:tickVisible="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/generation_settings_hint"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
